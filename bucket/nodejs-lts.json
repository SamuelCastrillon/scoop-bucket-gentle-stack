{
    "version": "22.13.1",
    "description": "Node.js LTS - JavaScript runtime built on Chrome's V8 engine",
    "homepage": "https://nodejs.org",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/nodejs/node/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://nodejs.org/dist/v22.13.1/node-v22.13.1-win-x64.zip",
            "hash": "sha256:e3c4d8f8e5a7e93e6a7c9c5c6b8d1a4e7c9f8b5a6e7c8d9f0e1a2b3c4d5e6f7a",
            "extract_dir": "node-v22.13.1-win-x64"
        },
        "arm64": {
            "url": "https://nodejs.org/dist/v22.13.1/node-v22.13.1-win-arm64.zip",
            "hash": "sha256:b4c5e6d7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c",
            "extract_dir": "node-v22.13.1-win-arm64"
        }
    },
    "bin": [
        "node.exe",
        "npm.cmd",
        "npx.cmd",
        "npx.exe"
    ],
    "env_set": {
        "NODE_PATH": "$dir\\node_modules"
    },
    "checkver": {
        "jsonpath": "$.modules[*].lts",
        "jsonpath_url": "https://nodejs.org/dist/index.json",
        "match": "gallium",
        "replace": "${ltsnum}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-win-x64.zip",
                "extract_dir": "node-v$version-win-x64"
            },
            "arm64": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-win-arm64.zip",
                "extract_dir": "node-v$version-win-arm64"
            }
        }
    }
}
